# Install CLIs (one-time)
sudo dnf install gh
sudo dnf install heroku       # or: curl https://cli-assets.heroku.com/install.sh | sh

# Run the deploy
cd /path/to/inventory_v2
bash scripts/deploy.sh
# Git init
cd /path/to/inventory_v2
git init
git add -A
git commit -m "Initial commit"

# GitHub
gh auth login
gh repo create inventory-v2 --public --push --source=. --remote=origin

# Heroku
heroku login
heroku create inventory-v2
heroku config:set JWT_SECRET="$(openssl rand -hex 32)" -a inventory-v2
heroku config:set ADMIN_USER=admin -a inventory-v2
heroku config:set ADMIN_PASS=admin123 -a inventory-v2
git push heroku main
heroku open -a inventory-v2
